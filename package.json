{
	"name": "@ceo.paludetto/pi-root",
	"private": true,
	"packageManager": "bun@1.3.14",
	"workspaces": {
		"packages": [
			"./packages/*"
		],
		"catalog": {
			"@earendil-works/pi-ai": "^0.80.2",
			"@earendil-works/pi-coding-agent": "^0.80.2",
			"@earendil-works/pi-tui": "^0.80.2",
			"better-result": "^2.9.2"
		}
	},
	"author": {
		"name": "Carlos Paludetto",
		"email": "ceo.paludetto@gmail.com"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ceopaludetto/pi"
	},
	"scripts": {
		"build": "turbo build",
		"start": "TURBO_UI=true turbo watch start --filter=@clutchify/application",
		"lint": "eslint . && sherif",
		"lint:fix": "eslint . --fix && sherif --fix",
		"test": "turbo test -- --pass-with-no-tests",
		"changeset:version": "changeset version && bun install",
		"changeset:publish": "for d in packages/*; do (cd \"$d\" && bun publish) || true; done && changeset tag"
	},
	"devDependencies": {
		"@antfu/eslint-config": "^9.1.0",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@total-typescript/tsconfig": "^1.0.4",
		"@types/node": "^26.0.0",
		"eslint": "^10.5.0",
		"eslint-plugin-format": "^2.0.1",
		"publint": "^0.3.21",
		"sherif": "^1.12.0",
		"tsdown": "^0.22.3",
		"turbo": "^2.10.0",
		"typescript": "^6.0.3"
	}
}
