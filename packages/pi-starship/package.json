{
	"name": "@ceo.paludetto/pi-starship",
	"type": "module",
	"version": "0.0.1",
	"description": "Starship-style status bar for pi with mode, model, tokens and path segments",
	"pi": {
		"extensions": [
			"./dist/index.mjs"
		]
	},
	"author": {
		"name": "Carlos Paludetto",
		"email": "ceo.paludetto@gmail.com"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ceopaludetto/pi.git",
		"directory": "packages/pi-starship"
	},
	"sideEffects": false,
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"scripts": {
		"build": "tsdown",
		"test": "bun test"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": ">=0.79.0",
		"@earendil-works/pi-coding-agent": ">=0.79.0",
		"@earendil-works/pi-tui": ">=0.79.0",
		"pi-mcp-adapter": ">=2.0.0"
	},
	"peerDependenciesMeta": {
		"pi-mcp-adapter": {
			"optional": true
		}
	},
	"dependencies": {
		"better-result": "catalog:"
	},
	"devDependencies": {
		"@ceo.paludetto/pi-utilities": "workspace:",
		"@earendil-works/pi-ai": "catalog:",
		"@earendil-works/pi-coding-agent": "catalog:",
		"@earendil-works/pi-tui": "catalog:"
	}
}
